# EvoMemBench root ignore rules.
# Keep benchmark source/data files unless they are generated, local, or too large for GitHub.

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# Python caches and build artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
build/
dist/
site/
*.egg-info/
*.egg
.eggs/
.pdm-build/
.pdm-python
__pypackages__/

# Virtual environments
.venv/
venv/
env/
ENV/
pyenv/
env.bak/
venv.bak/

# Node / frontend artifacts
node_modules/
.pnp/
.pnp.js
.yarn/install-state.gz
.next/
out/
dist-ssr/
coverage/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

